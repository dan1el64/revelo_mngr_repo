{
  "name": "order-intake-service-cdk",
  "version": "1.0.0",
  "description": "Optimized order intake service CDK application in TypeScript",
  "main": "app.ts",
  "scripts": {
    "build": "tsc",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "test": "jest",
    "test:unit": "ts-node -P tsconfig.json node_modules/.bin/jest --testPathPattern=unit_tests",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "aws-cdk-lib": "2.100.0",
    "constructs": "10.3.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.0",
    "@types/node": "20.10.0",
    "@typescript-eslint/eslint-plugin": "6.14.0",
    "@typescript-eslint/parser": "6.14.0",
    "jest": "29.5.0",
    "ts-jest": "29.1.0",
    "ts-node": "10.9.1",
    "typescript": "5.2.2",
    "aws-cdk": "2.100.0"
  }
}
